# OpenRouter API (обязательно)
OPENROUTER_API_KEY=sk-or-...
# Опционально: зафиксировать модель вместо авто-выбора
# OPENROUTER_MODEL=openai/gpt-oss-20b:free
# OPENROUTER_AGENT_MODEL=openrouter/free

# Локальный Langfuse (основной сценарий)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# Альтернатива: облачный Langfuse (раскомментируйте, если нет Docker)
# LANGFUSE_HOST=https://cloud.langfuse.com
